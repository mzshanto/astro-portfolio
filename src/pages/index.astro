---

<BaseLayout title={`${personalInfo.name} | ${personalInfo.title}`}>
  <!-- Fixed Stars Background (covers entire page) -->
  <StarsBackgroundWrapper client:load />

  <!-- Hero Section -->
  <HeroSection client:load personalInfo={personalInfo} metrics={metrics} />

  <!-- About Section (Bento Grid) -->
  <AboutSection client:load personalInfo={personalInfo} />

  <!-- Experience & Education Section (Timeline) -->
  <ExperienceSection client:load experiences={experiences} education={education} />

  <!-- Skills Section (Infinite Moving Cards) -->
  <SkillsSection client:load skills={skills} />

  <!-- Projects Section (Expandable Cards) -->
  <ProjectsSection client:load projects={projects} />

  <!-- Contact Section (Card Spotlight + Floating Dock) -->
  <ContactSection client:load personalInfo={personalInfo} />

  <!-- Footer -->
  <footer class="relative z-10 py-8 border-t border-neutral-800">
    <div class="absolute inset-0 bg-neutral-950/90"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <p class="text-neutral-500 text-sm">
          © {new Date().getFullYear()} {personalInfo.name}. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style is:global>
  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #171717;
  }

  ::-webkit-scrollbar-thumb {
    background: #404040;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #525252;
  }

  /* Selection color */
  ::selection {
    background: rgba(20, 184, 166, 0.3);
    color: white;
  }

  /* Focus styles for accessibility */
  *:focus-visible {
    outline: 2px solid #14b8a6;
    outline-offset: 2px;
  }
</style>